{
  "name": "obsidian-mcp",
  "version": "1.0.0",
  "description": "MCP server for Obsidian vault — full-text + semantic search, active recall with SM-2",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "lint": "tsc --noEmit",
    "rebuild:sqlite": "cd node_modules/better-sqlite3 && npm run build-release",
    "install:embeddings": "npm install @huggingface/transformers"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.6.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
}
