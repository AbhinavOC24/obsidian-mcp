# ─── Required ─────────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault directory (or the EC2 mirror)
VAULT_PATH=/home/ec2-user/vault

# Bearer token for the HTTP/SSE endpoint  (generate with: openssl rand -hex 32)
MCP_AUTH_TOKEN=change-me-to-a-strong-random-token

# ─── Optional ──────────────────────────────────────────────────────────────────

# Path for the SQLite database (defaults to ./data/obsidian-mcp.db)
DB_PATH=./data/obsidian-mcp.db

# Transport mode: "stdio" (default, for local/Claude Desktop) or "http" (EC2)
TRANSPORT=stdio

# HTTP port when TRANSPORT=http (default: 3000)
PORT=3000

# Log level: "debug" | "info" | "warn" | "error"  (default: info)
LOG_LEVEL=info

# Directory where @xenova/transformers caches the embedding model (~23 MB)
# Defaults to ~/.cache/huggingface (or TRANSFORMERS_CACHE env var)
# TRANSFORMERS_CACHE=/home/ec2-user/.cache/huggingface
